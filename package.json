{
  "name": "pet-rescue",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "web": "npm run dev --workspace=packages/web",
    "mobile": "npm run start --workspace=packages/mobile",
    "mobile:android": "npm run android --workspace=packages/mobile",
    "mobile:ios": "npm run ios --workspace=packages/mobile",
    "build:web": "npm run build --workspace=packages/web",
    "build:mobile:android": "npm run build:android --workspace=packages/mobile",
    "build:mobile:ios": "npm run build:ios --workspace=packages/mobile"
  },
  "dependencies": {
    "expo-build-properties": "~1.0.10"
  }
}
