rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 管理者判定（メールアドレスベース）
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'admin@gmail.com';
    }

    // ペット情報: 読み取りは全員、書き込みは認証済みユーザーのみ
    match /pets/{petId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || isAdmin()
            || request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['status', 'discoveryBonusGranted', 'updatedAt']));
      allow delete: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());

      // コメント
      match /comments/{commentId} {
        allow read: if true;
        allow create: if
          (request.auth != null && request.resource.data.userId == request.auth.uid)
          || (request.auth == null
              && request.resource.data.userId == null
              && request.resource.data.guestEmail is string
              && request.resource.data.guestEmail.size() > 0
              && request.resource.data.temporaryId is string);
        allow update: if request.auth != null
          && (resource.data.userId == request.auth.uid
              || get(/databases/$(database)/documents/pets/$(petId)).data.userId == request.auth.uid
              || (resource.data.userId == null
                  && request.resource.data.userId == request.auth.uid)
              || isAdmin());
        allow delete: if request.auth != null
          && (resource.data.userId == request.auth.uid || isAdmin());
      }
    }

    // ユーザー情報
    match /users/{userId} {
      allow read: if true;
      allow create, delete: if request.auth != null
        && request.auth.uid == userId;
      allow update: if request.auth != null
        && (request.auth.uid == userId
            || isAdmin()
            || request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['points', 'totalPointsEarned', 'titles', 'badges', 'selectedTitle',
                          'sightingCount', 'protectedPostCount', 'bestInfoCount', 'discoveryCount']));
    }

    // アプリ内通知
    match /notifications/{notificationId} {
      allow read: if isAdmin();
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if isAdmin();
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // 目撃投稿
    match /sightings/{sightingId} {
      allow read: if true;
      allow create: if
        (request.auth != null && request.resource.data.userId == request.auth.uid)
        || (request.auth == null
            && request.resource.data.userId == null
            && request.resource.data.guestEmail is string
            && request.resource.data.guestEmail.size() > 0
            && request.resource.data.temporaryId is string);
      allow update: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || isAdmin()
            || (resource.data.userId == null
                && request.resource.data.userId == request.auth.uid)
            || request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['isBestInfo', 'bestInfoPointGranted', 'updatedAt']));
      allow delete: if request.auth != null
        && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ポイント履歴: 認証済みユーザーが読み取り可能、更新・削除は管理者のみ
    match /point_transactions/{txId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // 景品マスタ: 読み取りは全員、作成・更新は管理者のみ
    match /rewards/{rewardId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // 景品交換申請
    match /reward_exchanges/{exchangeId} {
      allow read: if isAdmin();
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
