rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // ペット画像: 読み取りは全員、アップロードは認証済みユーザーのみ
    match /pets/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // 目撃投稿画像: 読み取りは全員、未ログイン含め誰でもアップロード可（5MB/画像のみ）
    match /sightings/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // コメント画像: 読み取りは全員、認証済みのみアップロード（既存ルールを保持）
    match /comments/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // アバター画像
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
